# ══════════════════════════════════════════════════
#  StudyVault — Environment Variables Template
#  Copy this file to .env.local and fill in values
# ══════════════════════════════════════════════════

# ── Supabase (Auth + Database + Storage) ─────────────────────────────────────
# Get from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── AI (Optional) ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# ── IPFS / Pinata (Optional — app uses Supabase Storage by default) ───────────
NEXT_PUBLIC_PINATA_API_KEY=your_pinata_api_key
NEXT_PUBLIC_PINATA_SECRET_KEY=your_pinata_secret_api_key
NEXT_PUBLIC_PINATA_JWT=your_pinata_jwt_token
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# ── Blockchain / Web3 (Optional) ──────────────────────────────────────────────
NEXT_PUBLIC_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_alchemy_key
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_CHAIN_NAME=Sepolia Testnet
NEXT_PUBLIC_SVT_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_SVT_NFT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_REWARDS_ADDRESS=0x0000000000000000000000000000000000000000

# ── App Config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=StudyVault
